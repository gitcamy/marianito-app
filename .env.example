# Copy to .env and fill in from Supabase → Project Settings → API Keys.
# With these set, the app talks to the real backend; without them it runs on
# local mocks. Restart `expo start` after changing (env is inlined at build).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
